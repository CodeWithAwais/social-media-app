// PostComposer — form with:
//   caption (textarea), imageUrl (input), category (select)
//   validate: caption required, imageUrl required
//   on submit → addPost from context → reset form

import { useState } from 'react'
import useFeed from '../hooks/useFeed'
import type { NewPostForm, Category } from '../types/index'

function PostComposer(){
    const { addPost } = useFeed();
    const [form, setForm] = useState<NewPostForm>({
        caption: '',
        imageUrl: '',
        category: 'tech'
    });

    const handleSubmit = (e: React.FormEvent<HTMLFormElement>) => {
        e.preventDefault();
        if (!form.caption || !form.imageUrl) return;
        addPost(form);
        setForm({
            caption: '',
            imageUrl: '',
            category: 'tech'
        });
    };

    return(
        <>
        
            <h1 className="text-2xl font-bold m-4">Create Post</h1>
        <div className="flex flex-col items-center justify-center w-full">
            <form onSubmit={handleSubmit} className="flex flex-col gap-2 p-4 border rounded-md shadow-md w-2/3 max-w-lg">
            <textarea className="border p-2 rounded-md" rows={3}
                placeholder="What's on your mind?"
                value={form.caption}
                onChange={(e) => setForm({...form, caption: e.target.value})}
            />
            <input className="border p-2 rounded-md"
                type="url"
                placeholder="Image URL"
                value={form.imageUrl}
                onChange={(e) => setForm({...form, imageUrl: e.target.value})}
            />
            <select className="border p-2 rounded-md"
                value={form.category}
                onChange={(e) => setForm({...form, category: e.target.value as Category})}
            >
                <option value="tech">Tech</option>
                <option value="lifestyle">Lifestyle</option>
                <option value="travel">Travel</option>
                <option value="food">Food</option>
            </select>
            <button type="submit" className="bg-blue-500 text-white p-2 rounded-md hover:bg-blue-600">
                Post
            </button>
        </form>
        </div>
        
        </>
    );
}

export default PostComposer;



